# Temporary files
trash/

# Framework tests 已入库（pnpm test / test:fast）；勿再 ignore

# 本地运维脚本默认不入库；Redis 引导必须随仓
scripts/*
!scripts/ensure-redis.mjs
!scripts/ensure-redis.cmd
*.reg

# 本地 Windows 注册表/卸载项清理备份（scripts/clean-empty-shell-uninstall.ps1）
xrk-uninstall-backup-*.reg

# Agent workspace local memories
memory/*.md
!memory/MEMORY.md
!memory/.gitkeep

# 业务 Core 本地部署，主仓 framework Core：system-Core
core/*
!core/system-Core/
!core/system-Core/**