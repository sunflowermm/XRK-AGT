# 运行期数据：见 data/.gitignore（整目录 *，仅 instruct.txt 例外）

# 子服务：构建产物与本地虚拟环境（源码 apis/* 示例保留入库）
subserver/pyserver/.venv/
subserver/goserver/goserver
subserver/goserver/goserver.exe
subserver/goserver/bin/
subserver/jserver/target/
subserver/rustserver/target/
