# Registry
registry=https://registry.npmmirror.com

# Binary mirrors
node_sqlite3_binary_host_mirror=https://npmmirror.com/mirrors/sqlite3
canvas_binary_host_mirror=https://npmmirror.com/mirrors/canvas
sharp_binary_host=https://npmmirror.com/mirrors/sharp
sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp-libvips

# Hoisting
shamefully-hoist=true
public-hoist-pattern[]=*sharp*

# Cache
side-effects-cache=false

# Strict mode
strict-peer-dependencies=false
auto-install-peers=true
save-exact=false

# Performance
prefer-frozen-lockfile=false

# Puppeteer 非默认渲染器；pnpm install 时跳过 Chromium 下载（需 Puppeteer 时可设 PUPPETEER_SKIP_DOWNLOAD=false）
puppeteer_skip_download=true

# Playwright 浏览器：bootstrap-deps.js 默认 cdn.npmmirror.com，404 时自动回退 cdn.playwright.dev
# 也可手动 export PLAYWRIGHT_DOWNLOAD_HOST / PLAYWRIGHT_CHROMIUM_DOWNLOAD_HOST