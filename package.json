{
  "name": "xrk-agt",
  "version": "2.0.9",
  "author": "Xrkseek",
  "description": "多平台、多Tasker、工作流驱动型智能体平台 - Multi-platform, multi-Tasker, workflow-driven intelligent agent platform",
  "main": "app.js",
  "type": "module",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunflowermm/XRK-AGT.git"
  },
  "license": "MIT",
  "keywords": [
    "bot",
    "framework",
    "ai",
    "chatbot"
  ],
  "imports": {
    "#utils/*": "./src/utils/*",
    "#core/*": "./core/*",
    "#config/*": "./config/*",
    "#data/*": "./data/*",
    "#renderers/*": "./src/renderers/*",
    "#modules/*": "./src/modules/*",
    "#infrastructure/*": "./src/infrastructure/*",
    "#factory/*": "./src/factory/*"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.61.1",
    "@mozilla/readability": "^0.6.0",
    "art-template": "^4.13.2",
    "chalk": "^5.4.1",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "compression": "^1.8.1",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.1.0",
    "figures": "^6.1.0",
    "file-type": "^21.3.0",
    "glob": "^13.0.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "image-size": "^2.0.2",
    "inquirer": "^8.2.5",
    "linkedom": "^0.18.12",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "mime": "^4.0.7",
    "moment": "^2.30.1",
    "multer": "^2.0.2",
    "node-schedule": "^2.1.1",
    "pino": "^10.3.0",
    "playwright": "^1.58.1",
    "pm2": "^6.0.14",
    "puppeteer": "^24.36.1",
    "redis": "^5.10.0",
    "rotating-file-stream": "^3.2.7",
    "screenshot-desktop": "^1.15.0",
    "sequelize": "^6.37.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.30.6",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-promise": "^7.2.1",
    "express-art-template": "^1.0.1"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "debug": "node debug.js",
    "setup:browsers": "node -e \"import { installPlaywrightChromium } from './src/utils/bootstrap-deps.js'; await installPlaywrightChromium();\"",
    "start:windows": "start.bat server",
    "start:unix": "./start.sh server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node tests/run.mjs unit",
    "test:all": "node tests/run.mjs all",
    "test:subservers": "node tests/subservers-smoke.mjs",
    "subservers:check": "node tests/subservers-check-env.mjs",
    "docker:clean": "node src/utils/docker-stack.mjs clean",
    "docker:build": "node src/utils/docker-stack.mjs build",
    "docker:build:browser": "node src/utils/docker-stack.mjs build xrk-agt --browser",
    "docker:up": "node src/utils/docker-stack.mjs up",
    "docker:down": "node src/utils/docker-stack.mjs down",
    "docker:status": "node src/utils/docker-stack.mjs status",
    "docker:fresh": "node src/utils/docker-stack.mjs fresh",
    "test:fast": "node tests/run.mjs fast",
    "test:integration": "node tests/run.mjs integration",
    "test:e2e": "node tests/run.mjs e2e",
    "test:perf": "node tests/perf/run-perf.mjs",
    "test:perf:smoke": "node tests/perf/run-perf.mjs smoke",
    "test:load": "node tests/perf/run-perf.mjs load",
    "test:stress": "node tests/perf/run-perf.mjs stress",
    "test:soak": "node tests/perf/run-perf.mjs soak",
    "test:bench": "node tests/perf/run-perf.mjs bench",
    "test:chaos": "node tests/perf/run-perf.mjs chaos"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "classic-level",
      "sqlite3",
      "log4js"
    ]
  }
}